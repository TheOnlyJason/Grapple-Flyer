{
  "name": "gale",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GALE — a kinetic sky-sailing endless runner. Web prototype of the core glide / tether-swing / slingshot loop.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "smoke": "node scripts/smoke.mjs",
    "shots": "node scripts/shot.mjs",
    "icons": "node scripts/icons.mjs",
    "assets": "node scripts/icons.mjs && cap assets generate --ios",
    "ios:sync": "npm run build && cap sync ios",
    "ios": "npm run build && cap sync ios && cap open ios"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@napi-rs/canvas": "^1.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1"
  }
}
